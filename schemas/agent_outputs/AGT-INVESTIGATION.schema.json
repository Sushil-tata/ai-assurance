{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "InvestigationAgentOutput",
  "type": "object",
  "required": ["correlation_id", "responding_agent_id", "status", "result"],
  "properties": {
    "correlation_id": { "type": "string" },
    "responding_agent_id": { "const": "AGT-INVESTIGATION" },
    "status": { "type": "string", "enum": ["success", "error", "escalated"] },
    "error_detail": { "type": "string" },
    "result": {
      "type": "object",
      "required": ["investigation_id", "hypotheses_tested", "status"],
      "properties": {
        "investigation_id": { "type": "string" },
        "hypotheses_tested": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "finding_id": { "type": "string" },
        "finding_statement": { "type": "string" },
        "root_cause_codes": { "type": "array", "items": { "type": "string" } },
        "evidence_item_ids": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Must be non-empty if finding_id is present — a finding with zero cited evidence items is a schema violation, enforced here in addition to the Assurance Agent's structural review."
        },
        "recommendation_id": { "type": "string" },
        "status": { "type": "string", "enum": ["pending_review", "needs_more_evidence"] }
      },
      "if": { "required": ["finding_id"] },
      "then": { "required": ["evidence_item_ids", "root_cause_codes"] }
    }
  }
}
