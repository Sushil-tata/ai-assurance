{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GetMonitoringMetricResponse",
  "type": "object",
  "required": ["status", "data"],
  "properties": {
    "status": { "type": "string", "enum": ["ok", "error"] },
    "data": {
      "type": "object",
      "properties": {
        "metric_code": { "type": "string" },
        "calculation_run_id": { "type": "string" },
        "run_date": { "type": "string", "format": "date" },
        "reference_population_def": { "type": "string" },
        "current_population_def": { "type": "string" },
        "metric_value": { "type": "number" },
        "sample_size_current": { "type": "integer" },
        "statistical_reliability_flag": { "type": "boolean" },
        "rag_status": { "type": "string", "enum": ["green", "amber", "red", "insufficient_sample"] },
        "calculation_version": { "type": "string" }
      },
      "required": ["metric_code", "calculation_run_id", "metric_value", "statistical_reliability_flag", "rag_status"]
    },
    "error": {
      "type": "object",
      "properties": { "code": { "type": "string" }, "message": { "type": "string" } }
    }
  }
}
